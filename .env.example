# Lovable auto-injects these at build time — do NOT commit a real .env.
# This file is the template; copy to .env locally if you need overrides
# and ensure .env is gitignored.

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Server-only (never put service-role keys here in production):
# SUPABASE_URL="..."
# SUPABASE_PUBLISHABLE_KEY="..."
